itle":"[Network] 물리 계층과 데이터 링크 계층","date":"2026년 3월 3일","dateISO":"2026-03-03","description":"물리 계층과 데이터 링크 계층에 대해 학습한 내용을 정리했습니다.","tags":["Network","물리 계층","데이터 링크 계층"]}},"previous":{"fields":{"slug":"/posts/weekly-contest-491/"},"frontmatter":{"title":"LeetCode Weekly Contest 491 후기"}},"next":null},"pageContext":{"id":"fbad8952-2e32-5983-8315-c68e7ea3aaad","previousPostId":"618453a3-97bd-5e77-8931-a2cfba7b970f","nextPostId":null}},"staticQueryHashes":["2637872971","3361002528","3414707483"],"slicesMap":{}}